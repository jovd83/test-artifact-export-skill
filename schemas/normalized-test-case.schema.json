{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Normalized Test Case Source",
  "type": "object",
  "properties": {
    "feature_title": { "type": "string" },
    "persona": { "type": "string" },
    "behavior": { "type": "string" },
    "value": { "type": "string" },
    "feature_tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "test_cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "objective": { "type": "string" },
          "coverage": { "type": "string" },
          "description": { "type": "string" },
          "preconditions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "action": { "type": "string" },
                "expected_result": { "type": "string" }
              }
            }
          },
          "expected_outcome": { "type": "string" },
          "requirements_coverage": {
            "type": "array",
            "items": { "type": "string" }
          },
          "execution_type": { "type": "string" },
          "design_status": { "type": "string" },
          "test_suite": { "type": "string" },
          "test_level": { "type": "string" },
          "test_engineer": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    },
    "scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "steps"],
        "properties": {
          "title": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "steps": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "zephyr_test_cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "steps"],
        "properties": {
          "folder": { "type": "string" },
          "name": { "type": "string" },
          "objective": { "type": "string" },
          "status": { "type": "string" },
          "precondition": { "type": "string" },
          "labels": {
            "type": "array",
            "items": { "type": "string" }
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "step": { "type": "string" },
                "expected_result": { "type": "string" }
              }
            }
          },
          "execution_type": { "type": "string" },
          "priority": { "type": "string" },
          "estimated_time": { "type": "string" },
          "is_open": { "type": "string" }
        }
      }
    }
  }
}
